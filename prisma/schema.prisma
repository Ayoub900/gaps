// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model InstructorsAcc {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  name      String
  country   String
  phone     Int
  job       String
  whatsapp  Int
  email     String

  @@map("InstructorsAccs")
}

model InternationalDiploma {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  name      String
  country   String
  phone     Int
  job       String
  whatsapp  Int
  email     String

  @@map("InternationalDiplomas")
}

model InstitutionsAcc {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt        DateTime @default(now())
  organizationName String
  ownerName        String
  country          String
  phone            Int
  field            String
  whatsapp         Int
  email            String
  website          String?
  facebook         String?

  @@map("InstitutionsAccs")
}

model id {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String?
  diploma   String?
  type      String?
  diplomas  String[]
  createdAt DateTime @default(now())
  imageUrl  String

  @@map("ids")
}

model post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  publish   Boolean?
  createdAt DateTime @default(now())
  imageUrl  String

  @@map("posts")
}

model application {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  title     String
  email     String
  phone     String
  country   String
  createdAt DateTime @default(now())

  @@map("applications")
}

model lpForm {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  lp          String
  name        String
  hasExp      String
  hasDiplomas String
  phone       String
  field       String
  createdAt   DateTime @default(now())

  @@map("lpForms")
}
