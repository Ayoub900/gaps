// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model InternationalDiploma {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  name      String
  country   String
  phone     Int
  job       String
  whatsapp  Int
  email     String

  @@map("InternationalDiplomas")
}

model id {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  code      String?
  cin       String?
  diploma   String?
  type      String?
  diplomas  String[]
  createdAt DateTime @default(now())

  @@map("ids")
}

model post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  publish   Boolean?
  createdAt DateTime @default(now())
  imageUrl  String

  @@map("posts")
}

model application {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  title     String
  email     String
  phone     String
  country   String
  createdAt DateTime @default(now())

  @@map("applications")
}

model lpForm {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  lp          String
  name        String
  hasExp      String
  hasDiplomas String
  phone       String
  field       String
  status      Status   @default(waiting)
  createdAt   DateTime @default(now())

  @@map("lpForms")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String?    @unique
  phone          String?
  emailVerified  DateTime?
  verified       Boolean?   @default(false)
  hashedPassword String?
  image          String?
  role           UserRole   @default(USER)
  courses        String[]
  accounts       Account[]
  sessions       Session[]
  online         DateTime[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("users")
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum Status {
  waiting
  processing
  processed
}
